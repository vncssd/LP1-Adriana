<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="620.0" prefWidth="680.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.FeiraController">
    <children>

        <Button layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#voltarMenu" text="Voltar" />
        <Text layoutX="295.0" layoutY="40.0" strokeType="OUTSIDE" strokeWidth="0.0" text="FEIRA">
            <font><Font size="21.0" /></font>
        </Text>

        <!-- ===== SEÇÃO FUNCIONÁRIOS ===== -->
        <Text layoutX="14.0" layoutY="65.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Funcionários">
            <font><Font size="13.0" /></font>
        </Text>

        <TextField fx:id="txtFldNomeFuncionario"    layoutX="14.0"  layoutY="75.0"  prefWidth="130.0" promptText="Nome" />
        <TextField fx:id="txtFldSalarioFuncionario" layoutX="152.0" layoutY="75.0"  prefWidth="110.0" promptText="Salário/hora (R$)" />
        <Button layoutX="270.0" layoutY="75.0" mnemonicParsing="false" onAction="#contratarFuncionario" prefWidth="100.0" text="Contratar" />
        <Button layoutX="378.0" layoutY="75.0" mnemonicParsing="false" onAction="#trabalhar"           prefWidth="110.0" text="Trabalhar (8h)" />
        <Button layoutX="496.0" layoutY="75.0" mnemonicParsing="false" onAction="#pagarSalario"        prefWidth="90.0"  text="Pagar Salário" />
        <Button layoutX="594.0" layoutY="75.0" mnemonicParsing="false" onAction="#demitirFuncionario"  prefWidth="72.0"  text="Demitir" />

        <TableView fx:id="tabelaFuncionarios" layoutX="14.0" layoutY="108.0" prefHeight="175.0" prefWidth="652.0">
            <columns>
                <TableColumn fx:id="colNome"   prefWidth="216.0" text="Nome" />
                <TableColumn fx:id="colSalario" prefWidth="218.0" text="Salário/Hora (R$)" />
                <TableColumn fx:id="colHoras"  prefWidth="218.0" text="Horas Trabalhadas" />
            </columns>
        </TableView>

        <Label fx:id="lblStatusBarraca" layoutX="14.0" layoutY="293.0" text="Status: fechada" />
        <Button layoutX="130.0" layoutY="289.0" mnemonicParsing="false" onAction="#abrirBarraca" prefWidth="110.0" text="Abrir Barraca" />

        <!-- ===== SEÇÃO PRODUTOS DA BARRACA ===== -->
        <Text layoutX="14.0" layoutY="330.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Produtos da Barraca">
            <font><Font size="13.0" /></font>
        </Text>

        <TextField fx:id="txtFldNomeProdutoFeira"  layoutX="14.0"  layoutY="340.0" prefWidth="160.0" promptText="Nome do produto" />
        <TextField fx:id="txtFldPrecoProdutoFeira" layoutX="182.0" layoutY="340.0" prefWidth="90.0"  promptText="Preço (R$)" />
        <TextField fx:id="txtFldQtdProdutoFeira"   layoutX="280.0" layoutY="340.0" prefWidth="70.0"  promptText="Qtd" />
        <Button layoutX="358.0" layoutY="340.0" mnemonicParsing="false" onAction="#adicionarProduto"   prefWidth="95.0" text="Adicionar" />
        <Button layoutX="461.0" layoutY="340.0" mnemonicParsing="false" onAction="#venderProdutoFeira" prefWidth="80.0" text="Vender" />
        <Button layoutX="549.0" layoutY="340.0" mnemonicParsing="false" onAction="#removerProduto"     prefWidth="80.0" text="Remover" />

        <TableView fx:id="tabelaProdutosFeira" layoutX="14.0" layoutY="373.0" prefHeight="200.0" prefWidth="652.0">
            <columns>
                <TableColumn fx:id="colNomeProduto" prefWidth="260.0" text="Produto" />
                <TableColumn fx:id="colPrecoProduto" prefWidth="196.0" text="Preço (R$)" />
                <TableColumn fx:id="colQtdProduto"   prefWidth="196.0" text="Quantidade em Estoque" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
